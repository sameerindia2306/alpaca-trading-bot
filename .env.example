# ── Alpaca ────────────────────────────────────────────────────
# Get these from alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Telegram ──────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message your bot once, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" value from "chat" → that's your CHAT_ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Risk settings ─────────────────────────────────────────────
PORTFOLIO_VALUE_USD=2000
RISK_PCT=1                  # % of portfolio per FULL trade ($20 at $2k)
MAX_TRADES_PER_DAY=20
MAX_OPEN_POSITIONS=5
